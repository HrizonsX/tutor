{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*.js", "types/**/*.d.ts"],
  "exclude": ["test", "node_modules"]
}
