{
  "name": "browser-cognitive-overlay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A quiet browser learning overlay that explains concepts only when reading signals and memory justify it.",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "gateway:dev": "node scripts/local-gateway-dev.js",
    "gateway:stub": "node scripts/local-gateway-dev.js --stub-explain",
    "smoke:pre-recall": "node scripts/pre-recall-browser-smoke-server.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "test": "node --test \"test/**/*.test.js\"",
    "test:ci": "node --test \"test/**/*.test.js\"",
    "test:integration": "node --test test/layered-memory-integration.test.js",
    "typecheck": "tsc -p tsconfig.json",
    "check": "npm run typecheck && npm run test:ci"
  },
  "dependencies": {
    "better-sqlite3": "^12.5.0",
    "pg": "^8.13.1",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^6.0.3"
  }
}
